PORT=8791

# Local demo credentials. Use HTTP Basic Auth: base64(API_KEY:API_SECRET)
API_KEY=local-key
API_SECRET=local-secret

# Optional Web demo password. If empty, the Web page is not password-protected.
WEB_PASSWORD=
WEB_SESSION_COOKIE=pg_web_session
# Set true only when the site is served over HTTPS.
WEB_COOKIE_SECURE=false

# Keep true for local smoke tests without calling a real model.
MOCK_QWEN=true
LLM_TRANSPORT=direct

# Use DashScope OpenAI-compatible endpoint when MOCK_QWEN=false.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-max
QWEN_ENABLE_THINKING=false
LLM_MAX_TOKENS=2400

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

DISPATCHER_BASE_URL=http://47.100.137.178:8080
DISPATCHER_USERNAME=
DISPATCHER_PASSWORD=
DISPATCHER_PROXY=false

# In-memory local queue concurrency. Production should use Redis/DB + worker.
MAX_CONCURRENT_JOBS=2

META_PROMPT_VERSION=outbound-v0.1.0
META_PROMPT_PATH=prompts/outbound-v0.md

# Optional Langfuse tracing. Keep disabled unless keys are configured.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=local
LANGFUSE_REDACT_IO=false
